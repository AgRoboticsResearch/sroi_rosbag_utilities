{
  "_doc": "Filter rules for visualization/ik_feasibility.py (EXPERIMENTAL). Loaded at import; override with --filters. Runs Piper IK over recorded SROI camera trajectories and reports feasibility. Not wired into the production pipeline.",
  "version": 1,

  "robot": {
    "_doc_urdf": "Canonical deploy URDF (sroi-piper submodule). urdf_fallback_path is used if urdf_path is missing.",
    "urdf_path": "/home/zfei/code/lerobots/lerobot/sroi-piper/src/utils/piper_urdf/piper.urdf",
    "urdf_fallback_path": "/home/zfei/code/lerobots/lerobot/traj_execution_test/piper_mujoco/piper_description.urdf",
    "lerobot_src_path": "/home/zfei/code/lerobots/lerobot/src",
    "target_frame_name": "camera_link",
    "joint_names": ["joint1", "joint2", "joint3", "joint4", "joint5", "joint6"]
  },

  "seed_poses": {
    "_doc": "Named arm seeds (degrees), joint1..joint6. 'start' = the pose the deploy moves to before control engages (the actual ready pose, since the deploy command runs without --warm_start). 'home' is only reached with --warm_start.",
    "start": [-0.55, 79.2, -31.3, -1.59, -45.85, 6.2],
    "home":  [0.0, 50.60, -50.40, -1.21, 10.00, 0.0],
    "safe":  [-0.66, -2.08, 1.8, 1.35, 17.16, 0.0]
  },
  "default_seed_name": "start",

  "ik": {
    "_doc": "placo IK weights + acceptance tolerances. orientation_weight 0.1 matches piper_traj_test.py.",
    "position_weight": 1.0,
    "orientation_weight": 0.1,
    "position_tol_m": 0.02,
    "rotation_tol_rad": 0.3
  },

  "trajectory": {
    "_doc": "traj_filename is the same file qc.py + sroi_to_lerobot consume (camera_link convention).",
    "traj_filename": "CameraTrajectoryTransformed.txt",
    "max_joint_step_deg": 30.0,
    "max_ee_step_m": 0.05,
    "joint_limit_margin_deg": 1.0,
    "ee_bounds_min": [-0.5, -0.5, -0.1],
    "ee_bounds_max": [0.5, 0.5, 0.6]
  },

  "thresholds": {
    "min_traj_frames": 30,
    "max_failed_ratio": 0.1
  },

  "categories": {
    "ik_no_traj":     {"color": "#757575", "problem": true,  "priority": 0, "description": "no/short trajectory"},
    "ik_joint_limit": {"color": "#c62828", "problem": true,  "priority": 1, "description": "a solved joint is outside URDF limits (+margin)"},
    "ik_branch_jump": {"color": "#6a1b9a", "problem": true,  "priority": 2, "description": "per-joint step > max_joint_step_deg (elbow flip / discontinuity)"},
    "ik_unreachable": {"color": "#ef6c00", "problem": true,  "priority": 3, "description": "failed-ratio > max_failed_ratio (FK residual over tol)"},
    "ik_ok":          {"color": "#2e7d32", "problem": false, "priority": 4, "description": "trackable from the seed within tolerance"}
  },

  "display": {
    "category_default_color": "#999999",
    "panel_background": "#f5f7fa",
    "episodes_per_row": 1,
    "figsize_session": [11.0, 8.0],
    "figsize_summary": [11.0, 0.42],
    "figsize_summary_base_height": 1.6,
    "outer_hspace": 0.22,
    "outer_margins": [0.06, 0.98, 0.96, 0.05],
    "err_color": "#1565c0",
    "rot_color": "#00838f",
    "joint_palette": ["#e6194b", "#3cb44b", "#ffe119", "#4363d8", "#f58231", "#911eb4"],
    "limit_color": "#c62828"
  }
}
